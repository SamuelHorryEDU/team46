// Here's what to do in order to connect to the database:
// Copy the below lines to a new file "db.properties" in the project root directory
// (aka, the same folder as this file, db.properties.example)
// This db.properties file will be ignored by git, so it wont be added to your commits.

db.url=jdbc:mysql://localhost:3306/ipos_sa_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
db.user=root
db.password=your_password_here
